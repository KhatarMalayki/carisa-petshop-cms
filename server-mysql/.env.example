# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Database Configuration (MySQL di Laragon)
DATABASE_URL="mysql://root:@localhost:3306/carisa_petshop"

# Jika pakai password MySQL:
